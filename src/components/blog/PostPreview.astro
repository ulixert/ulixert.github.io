---
import type { CollectionEntry } from "astro:content";
import type { HTMLTag, Polymorphic } from "astro/types";
import FormattedDate from "@/components/FormattedDate.astro";

type Props<Tag extends HTMLTag> = Polymorphic<{ as: Tag }> & {
	post: CollectionEntry<"post">;
	withDesc?: boolean;
};

const { as: Tag = "div", post, withDesc = false } = Astro.props;
---

<div class="grid gap-2 sm:grid-cols-[120px_1fr] sm:gap-x-8">
	<div class="text-gray-600 dark:text-gray-400 pt-1">
		{
			post.data.updatedDate && post.data.updatedDate.getTime() !== post.data.publishDate.getTime() && (
				<span class="text-xs block mb-1">Updated:</span>
			)
		}
		<FormattedDate date={post.data.updatedDate ?? post.data.publishDate} />
	</div>
	<div class="flex flex-col gap-y-1">
		<Tag>
			{post.data.draft && <span class="text-red-500">(Draft) </span>}
			<a class="cactus-link text-lg font-semibold" href={`/posts/${post.id}/`}>
				{post.data.title}
			</a>
		</Tag>
		{withDesc && <p class="line-clamp-3 text-gray-600 dark:text-gray-400">{post.data.description}</p>}
	</div>
</div>
